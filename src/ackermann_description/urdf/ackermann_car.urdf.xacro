<?xml version="1.0"?>
<robot name="ackermann_car" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ===================== -->
  <!-- Parameters -->
  <!-- ===================== -->
  <xacro:property name="base_length" value="0.60"/>
  <xacro:property name="base_width"  value="0.32"/>
  <xacro:property name="base_height" value="0.12"/>
  <xacro:property name="base_mass"   value="5.0"/>

  <xacro:property name="wheel_radius" value="0.07"/>
  <xacro:property name="wheel_width"  value="0.04"/>
  <xacro:property name="wheel_mass"   value="0.25"/>

  <xacro:property name="steer_link_radius" value="0.025"/>
  <xacro:property name="steer_link_length" value="0.04"/>
  <xacro:property name="steer_link_mass"   value="0.10"/>

  <xacro:property name="front_x" value="0.22"/>
  <xacro:property name="rear_x"  value="-0.22"/>
  <xacro:property name="left_y"  value="0.19"/>
  <xacro:property name="right_y" value="-0.19"/>

  <!-- ===================== -->
  <!-- Materials -->
  <!-- ===================== -->
  <material name="blue">
    <color rgba="0.1 0.2 0.8 1.0"/>
  </material>

  <material name="black">
    <color rgba="0.02 0.02 0.02 1.0"/>
  </material>

  <material name="gray">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>

  <material name="red">
    <color rgba="0.8 0.1 0.1 1.0"/>
  </material>

  <!-- ===================== -->
  <!-- Inertia Macros -->
  <!-- ===================== -->
  <xacro:macro name="box_inertia" params="m x y z">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${m}"/>
      <inertia
        ixx="${m / 12.0 * (y * y + z * z)}"
        ixy="0.0"
        ixz="0.0"
        iyy="${m / 12.0 * (x * x + z * z)}"
        iyz="0.0"
        izz="${m / 12.0 * (x * x + y * y)}"/>
    </inertial>
  </xacro:macro>

  <!-- wheel axis is Y -->
  <xacro:macro name="wheel_inertia_y_axis" params="m r l">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${m}"/>
      <inertia
        ixx="${m / 12.0 * (3.0 * r * r + l * l)}"
        ixy="0.0"
        ixz="0.0"
        iyy="${0.5 * m * r * r}"
        iyz="0.0"
        izz="${m / 12.0 * (3.0 * r * r + l * l)}"/>
    </inertial>
  </xacro:macro>

  <!-- small steering cylinder axis is Z -->
  <xacro:macro name="cylinder_inertia_z_axis" params="m r l">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${m}"/>
      <inertia
        ixx="${m / 12.0 * (3.0 * r * r + l * l)}"
        ixy="0.0"
        ixz="0.0"
        iyy="${m / 12.0 * (3.0 * r * r + l * l)}"
        iyz="0.0"
        izz="${0.5 * m * r * r}"/>
    </inertial>
  </xacro:macro>

  <!-- ===================== -->
  <!-- Base Link -->
  <!-- ===================== -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${base_height / 2.0}" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="blue"/>
    </visual>

    <collision>
      <origin xyz="0 0 ${base_height / 2.0}" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>

    <xacro:box_inertia
      m="${base_mass}"
      x="${base_length}"
      y="${base_width}"
      z="${base_height}"/>
  </link>

  <!-- ===================== -->
  <!-- Front Steering Link Macro -->
  <!-- ===================== -->
  <xacro:macro name="front_steer_module" params="side y">
    <link name="front_${side}_steer_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${steer_link_radius}" length="${steer_link_length}"/>
        </geometry>
        <material name="red"/>
      </visual>

      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${steer_link_radius}" length="${steer_link_length}"/>
        </geometry>
      </collision>

      <xacro:cylinder_inertia_z_axis
        m="${steer_link_mass}"
        r="${steer_link_radius}"
        l="${steer_link_length}"/>
    </link>

    <joint name="front_${side}_steer_joint" type="revolute">
      <parent link="base_link"/>
      <child link="front_${side}_steer_link"/>
      <origin xyz="${front_x} ${y} ${wheel_radius}" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="-0.6" upper="0.6" effort="10.0" velocity="2.0"/>
    </joint>

    <link name="front_${side}_wheel_link">
      <visual>
        <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="black"/>
      </visual>

      <collision>
        <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>

      <xacro:wheel_inertia_y_axis
        m="${wheel_mass}"
        r="${wheel_radius}"
        l="${wheel_width}"/>
    </link>

    <joint name="front_${side}_wheel_joint" type="continuous">
      <parent link="front_${side}_steer_link"/>
      <child link="front_${side}_wheel_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <!-- ===================== -->
  <!-- Rear Wheel Macro -->
  <!-- ===================== -->
  <xacro:macro name="rear_wheel" params="side y">
    <link name="rear_${side}_wheel_link">
      <visual>
        <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="black"/>
      </visual>

      <collision>
        <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>

      <xacro:wheel_inertia_y_axis
        m="${wheel_mass}"
        r="${wheel_radius}"
        l="${wheel_width}"/>
    </link>

    <joint name="rear_${side}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="rear_${side}_wheel_link"/>
      <origin xyz="${rear_x} ${y} ${wheel_radius}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <!-- ===================== -->
  <!-- Instantiate Wheels -->
  <!-- ===================== -->
  <xacro:front_steer_module side="left"  y="${left_y}"/>
  <xacro:front_steer_module side="right" y="${right_y}"/>

  <xacro:rear_wheel side="left"  y="${left_y}"/>
  <xacro:rear_wheel side="right" y="${right_y}"/>

  <!-- ===================== -->
  <!-- Laser Placeholder -->
  <!-- ===================== -->
  <link name="laser_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.04"/>
      </geometry>
      <material name="gray"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.04"/>
      </geometry>
    </collision>

    <xacro:cylinder_inertia_z_axis m="0.1" r="0.04" l="0.04"/>
  </link>

  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_link"/>
    <origin xyz="0.18 0 0.18" rpy="0 0 0"/>
  </joint>

</robot>